      "        {step === \"phone\" && (",
      "          <div className=\"space-y-1\">",
      "            <label htmlFor=\"phone\" className=\"block text-sm font-medium text-gray-700\">Mobile number</label>",
      "            <input id=\"phone\" type=\"tel\" required value={phone} onChange={(e) => setPhone(e.target.value)} placeholder=\"+91 98xxxxxx00\" className=\"w-full rounded-md border border-gray-300 px-3 py-2\" />",
      "          </div>",
      "        )}",
