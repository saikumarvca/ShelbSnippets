      "            <div key={n} className={`flex-1 h-1 rounded ${n <= step ? \"bg-blue-600\" : \"bg-gray-200\"}`} />",
      "          ))}",
      "        </div>",
      "        <h1 className=\"text-2xl font-semibold text-gray-900\">Set up your ${4:Shelb} account · Step {step} of 3</h1>",
