      "              <label htmlFor=\"name\" className=\"block text-sm font-medium text-gray-700\">Full name</label>",
      "              <input id=\"name\" type=\"text\" required value={name} onChange={(e) => setName(e.target.value)} className=\"w-full rounded-md border border-gray-300 px-3 py-2\" />",
      "            </div>",
