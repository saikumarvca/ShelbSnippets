      "        body: JSON.stringify({ phone, otp, name, step }),",
      "      });",
      "      if (!res.ok) throw new Error(\"Something went wrong. Please retry.\");",
      "      if (step === \"phone\") setStep(\"otp\");",
      "      else if (step === \"otp\") setStep(\"profile\");",
