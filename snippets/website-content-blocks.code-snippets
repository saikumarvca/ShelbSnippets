      "          <div><label className=\"text-sm font-medium\" htmlFor={sectionId + \"-email\"}>Email</label><input id={sectionId + \"-email\"} value={email} onChange={(e) => setEmail(e.target.value)} aria-invalid={errors.email} type=\"email\" className={\"mt-1 h-11 w-full rounded-md border px-3 text-sm \" + (errors.email ? \"border-red-400\" : \"border-gray-300\")} /></div>",
      "          <div><label className=\"text-sm font-medium\" htmlFor={sectionId + \"-msg\"}>Message (10+ chars)</label><textarea id={sectionId + \"-msg\"} value={msg} onChange={(e) => setMsg(e.target.value)} rows={4} aria-invalid={errors.msg} className={\"mt-1 w-full rounded-md border p-3 text-sm \" + (errors.msg ? \"border-red-400\" : \"border-gray-300\")} /></div>",
