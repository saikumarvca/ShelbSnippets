  "Shelb React Hook — useFetch (srehook08)": {
    "prefix": "srehook08",
    "description": "Tiny declarative fetch with status state.",
    "body": [
      "import { useCallback, useEffect, useRef, useState } from \"react\";",
      "",
      "export function useFetch<T = unknown>(url: string, init?: RequestInit) {",
      "  const [data, setData] = useState<T | null>(null);",
      "  const [error, setError] = useState<Error | null>(null);",
      "  const [loading, setLoading] = useState(true);",
      "  useEffect(() => {",
      "    let alive = true;",
      "    setLoading(true);",
      "    fetch(url, init)",
      "      .then((r) => { if (!r.ok) throw new Error(r.statusText); return r.json() as Promise<T>; })",
      "      .then((d) => { if (alive) { setData(d); setError(null); } })",
      "      .catch((e) => alive && setError(e))",
      "      .finally(() => alive && setLoading(false));",
      "    return () => { alive = false; };",
      "  }, [url]);",
      "  return { data, error, loading } as const;",
      "}",
      "$0"
    ]
  },
