      "export function usePagination(total: number, pageSize: number = 10) {",
      "  const [page, setPage] = useState(1);",
      "  const pageCount = Math.max(1, Math.ceil(total / pageSize));",
      "  const next = () => setPage((p) => Math.min(p + 1, pageCount));",
