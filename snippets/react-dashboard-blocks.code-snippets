  "Shelb React Table — Sortable Columns (sretable18)": {
    "prefix": "sretable18",
    "description": "Table with sortable columns and a direction indicator.",
    "body": [
      "import React, { useState } from \"react\";",
      "",
      "interface ${1:SortableTable}Props {",
      "  ${9:items}?: { id: string; name: string; value: number }[];",
      "  ${5:className}?: string;",
      "}",
      "",
      "export function ${1:SortableTable}({ ${9:items} = [{ id: \"1\", name: \"Acme\", value: 1200 }, { id: \"2\", name: \"Tata\", value: 4800 }, { id: \"3\", name: \"Infosys\", value: 800 }], ${5:className} = \"\" }: ${1:SortableTable}Props) {",
      "  const [sort, setSort] = useState<{ key: \"name\" | \"value\"; dir: \"asc\" | \"desc\" }>({ key: \"name\", dir: \"asc\" });",
      "  const rows = [...${9:items}].sort((a, b) => {",
      "    const av = a[sort.key]; const bv = b[sort.key];",
      "    if (av < bv) return sort.dir === \"asc\" ? -1 : 1;",
      "    if (av > bv) return sort.dir === \"asc\" ? 1 : -1;",
      "    return 0;",
      "  });",
      "  function head(key: \"name\" | \"value\", label: string) {",
      "    const active = sort.key === key;",
      "    return <button type=\"button\" onClick={() => setSort({ key, dir: active && sort.dir === \"asc\" ? \"desc\" : \"asc\" })} className=\"inline-flex items-center gap-1\">{label}<span aria-hidden=\"true\" className={active ? \"\" : \"opacity-30\"}>{active && sort.dir === \"desc\" ? \"↓\" : \"↑\"}</span></button>;",
      "  }",
      "  return (",
      "    <div className={\"rounded-xl border border-gray-200 bg-white overflow-hidden \" + ${5:className}}>",
      "      <table className=\"w-full text-sm\">",
      "        <thead className=\"bg-gray-50 text-left text-xs uppercase tracking-wider text-gray-500\"><tr><th className=\"px-4 py-3\">ID</th><th className=\"px-4 py-3\">{head(\"name\", \"Name\")}</th><th className=\"px-4 py-3\">{head(\"value\", \"Value\")}</th></tr></thead>",
      "        <tbody className=\"divide-y divide-gray-100\">",
      "          {rows.map((r) => (<tr key={r.id}><td className=\"px-4 py-3 font-mono text-xs\">{r.id}</td><td className=\"px-4 py-3\">{r.name}</td><td className=\"px-4 py-3 font-medium\">{r.value}</td></tr>))}",
      "        </tbody>",
      "      </table>",
      "    </div>",
      "  );",
      "}$0"
    ]
  },

