  "Shelb React Table — Pagination (sretable14)": {
    "prefix": "sretable14",
    "description": "Table with a pagination footer (prev / next + page indicator).",
    "body": [
      "import React, { useState } from \"react\";",
      "",
      "interface ${1:PaginatedTable}Props {",
      "  ${9:items}?: { id: string; name: string }[];",
      "  pageSize?: number;",
      "  ${5:className}?: string;",
      "}",
      "",
      "export function ${1:PaginatedTable}({ ${9:items} = Array.from({ length: 23 }).map((_, i) => ({ id: String(i + 1), name: \"Record \" + (i + 1) })), pageSize = 5, ${5:className} = \"\" }: ${1:PaginatedTable}Props) {",
      "  const [page, setPage] = useState(1);",
      "  const totalPages = Math.max(1, Math.ceil(${9:items}.length / pageSize));",
      "  const rows = ${9:items}.slice((page - 1) * pageSize, page * pageSize);",
      "  return (",
      "    <div className={\"rounded-xl border border-gray-200 bg-white \" + ${5:className}}>",
      "      <table className=\"w-full text-sm\">",
      "        <thead className=\"bg-gray-50 text-left text-xs uppercase tracking-wider text-gray-500\"><tr><th className=\"px-4 py-3\">ID</th><th className=\"px-4 py-3\">Name</th></tr></thead>",
      "        <tbody className=\"divide-y divide-gray-100\">",
      "          {rows.map((r) => (<tr key={r.id}><td className=\"px-4 py-3 font-mono text-xs\">{r.id}</td><td className=\"px-4 py-3\">{r.name}</td></tr>))}",
      "        </tbody>",
      "      </table>",
      "      <div className=\"p-3 border-t border-gray-100 flex items-center justify-between text-sm\">",
      "        <span className=\"text-gray-500\">Page {page} of {totalPages}</span>",
      "        <div className=\"space-x-1\">",
      "          <button type=\"button\" disabled={page <= 1} onClick={() => setPage(page - 1)} className=\"rounded-md border border-gray-200 px-2 py-1 disabled:opacity-50\">Prev</button>",
      "          <button type=\"button\" disabled={page >= totalPages} onClick={() => setPage(page + 1)} className=\"rounded-md border border-gray-200 px-2 py-1 disabled:opacity-50\">Next</button>",
      "        </div>",
      "      </div>",
