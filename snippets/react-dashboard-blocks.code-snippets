      "  const [touched, setTouched] = useState({ name: false, email: false });",
      "  const nameError = !name ? \"Name is required\" : name.length < 2 ? \"Too short\" : \"\";",
      "  const emailError = !email ? \"Email is required\" : !/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email) ? \"Invalid email\" : \"\";",
