  "Shelb Offer — Offer with countdown placeholder (seoffer11)": {
    "prefix": "seoffer11",
    "description": "Offer with countdown placeholder.",
    "body": [
      "import React, { useState, useEffect } from \"react\";",
      "",
      "interface Seoffer11Props {",
      "  title?: string;",
      "  subtitle?: string;",
      "  description?: string;",
      "  buttonText?: string;",
      "  buttonHref?: string;",
      "  imageUrl?: string;",
      "  className?: string;",
      "  sectionId?: string;",
      "}",
      "",
      "export function Seoffer11({",
      "  title = \"${1:Ends in 06:00:00}\",",
      "  subtitle = \"${2:Countdown offer}\",",
      "  description = \"${3:Drop in a real countdown timer where the placeholder shows.}\",",
      "  buttonText = \"${4:Shop now}\",",
      "  buttonHref = \"${5:/shop}\",",
      "  imageUrl = \"${6:}\",",
      "  className = \"${7:}\",",
      "  sectionId = \"${8:seoffer-countdown}\",",
      "}: Seoffer11Props) {",
      "",
      "  const [time, setTime] = useState({ h: 6, m: 0, s: 0 });",
      "  useEffect(() => {",
      "    const id = setInterval(() => setTime((t) => {",
      "      if (t.s > 0) return { ...t, s: t.s - 1 };",
      "      if (t.m > 0) return { ...t, m: t.m - 1, s: 59 };",
      "      if (t.h > 0) return { h: t.h - 1, m: 59, s: 59 };",
      "      return t;",
      "    }), 1000);",
      "    return () => clearInterval(id);",
      "  }, []);",
      "",
      "  const pad = (n: number) => String(n).padStart(2, \"0\");",
      "",
      "  return (",
      "    <section id={sectionId} aria-labelledby={sectionId + \"-title\"} className={\"bg-red-50 text-gray-900 py-12 px-6 \" + className}>",
      "      <div className=\"mx-auto max-w-4xl rounded-2xl bg-white p-6 text-center\">",
      "        <p className=\"text-xs font-semibold uppercase tracking-widest text-red-700\">{subtitle}</p>",
      "        <h2 id={sectionId + \"-title\"} className=\"mt-1 text-3xl font-bold tracking-tight\"><span className=\"font-mono\">{pad(time.h)}:{pad(time.m)}:{pad(time.s)}</span></h2>",
      "        <p className=\"mt-2 text-sm text-gray-600\">{description}</p>",
      "        <a href={buttonHref} className=\"mt-6 inline-flex h-11 items-center rounded-md bg-red-600 px-6 text-sm font-semibold text-white hover:bg-red-700\">{buttonText}</a>",
      "      </div>",
      "    </section>",
      "  );",
      "}",
      "$0"
    ]
  },
