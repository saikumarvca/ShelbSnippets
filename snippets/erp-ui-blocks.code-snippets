  "Shelb ERP Login — Basic (serplogin01)": {
    "prefix": "serplogin01",
    "description": "Basic ERP login (email + password) with company placeholder.",
    "body": [
      "import React, { useState, FormEvent } from \"react\";",
      "",
      "interface ${1:Basic}Props { className?: string; }",
      "",
      "export default function ${1:Basic}({ className = \"\" }: ${1:Basic}Props) {",
      "  const [form, setForm] = useState({ email: \"\", password: \"\" });",
      "  const [loading, setLoading] = useState(false);",
      "  const [error, setError] = useState<string | null>(null);",
      "",
      "  async function submit(e: FormEvent<HTMLFormElement>) {",
      "    e.preventDefault();",
      "    setLoading(true); setError(null);",
      "    try {",
      "      const res = await fetch(\"${6:/api/erp/auth/login}\", {",
      "        method: \"POST\", headers: { \"Content-Type\": \"application/json\" },",
      "        body: JSON.stringify({ ...form, company: \"${2:Shelb Corp}\", branch: \"${3:HQ}\", fy: \"${4:2025-26}\", role: \"${5:user}\" }),",
      "      });",
      "      if (!res.ok) throw new Error(\"Sign-in failed. Check credentials.\");",
      "      window.location.href = \"${7:/erp/dashboard}\";",
      "    } catch (err) { setError((err as Error).message); }",
      "    finally { setLoading(false); }",
      "  }",
      "",
      "  return (",
      "    <div className={\"min-h-screen bg-slate-50 flex items-center justify-center px-4 \" + className}>",
      "      <form onSubmit={submit} className=\"w-full max-w-md bg-white border border-slate-200 rounded-2xl shadow-lg p-8 space-y-5\">",
      "        <header>",
      "          <h1 className=\"text-xl font-semibold text-slate-900\">${2:Shelb Corp} ERP</h1>",
      "          <p className=\"text-sm text-slate-500\">Sign in to your enterprise workspace.</p>",
      "        </header>",
      "        {error && <div role=\"alert\" className=\"rounded-md bg-rose-50 text-rose-700 text-sm px-3 py-2\">{error}</div>}",
      "        <div className=\"space-y-1\">",
      "          <label className=\"text-sm font-medium text-slate-700\">Work email</label>",
      "          <input type=\"email\" required value={form.email} onChange={(e) => setForm({ ...form, email: e.target.value })} className=\"w-full rounded-md border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500\" />",
      "        </div>",
      "        <div className=\"space-y-1\">",
      "          <label className=\"text-sm font-medium text-slate-700\">Password</label>",
      "          <input type=\"password\" required value={form.password} onChange={(e) => setForm({ ...form, password: e.target.value })} className=\"w-full rounded-md border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500\" />",
