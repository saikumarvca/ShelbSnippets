  "Shelb ERP Table — Basic (serptable01)": {
    "prefix": "serptable01",
    "description": "Basic ERP data table with search and empty state.",
    "body": [
      "import React, { useMemo, useState } from \"react\";",
      "",
      "interface ${1:BasicERPTable}Props { className?: string; }",
      "",
      "export function ${1:BasicERPTable}({ className = \"\" }: ${1:BasicERPTable}Props) {",
      "  const columns = [{ key: \"code\", label: \"Code\" }, { key: \"name\", label: \"Name\" }, { key: \"status\", label: \"Status\" }];",
      "  const data = [{\"code\":\"REC-001\",\"name\":\"Sample A\",\"status\":\"Active\"}, {\"code\":\"REC-002\",\"name\":\"Sample B\",\"status\":\"Inactive\"}, {\"code\":\"REC-003\",\"name\":\"Sample C\",\"status\":\"Draft\"}];",
      "  const [query, setQuery] = useState(\"\");",
      "  const rows = useMemo(() => data.filter((r) => Object.values(r).some((v) => String(v).toLowerCase().includes(query.toLowerCase()))), [query]);",
      "  return (",
      "    <section className={\"bg-white rounded-2xl border border-slate-200 \" + className}>",
      "      <header className=\"flex items-center justify-between p-4 border-b border-slate-100\"><div><h2 className=\"text-base font-semibold text-slate-900\">Records</h2><p className=\"text-xs text-slate-500\">${2:Shelb Corp} · ${3:HQ}</p></div>",
      "        <input value={query} onChange={(e) => setQuery(e.target.value)} placeholder=\"Search…\" className=\"rounded-md border border-slate-300 px-3 py-1.5 text-sm\" />",
      "      </header>",
      "      <div className=\"overflow-x-auto\">",
      "        <table className=\"w-full text-sm\">",
      "          <thead className=\"bg-slate-50 text-slate-600\">",
      "            <tr>{columns.map((c) => (<th key={c.key} className={\"px-4 py-2 text-\" + ((c as any).align || \"left\") + \" font-medium\"}>{c.label}</th>))}</tr>",
      "          </thead>",
      "          <tbody>",
      "            {rows.map((r, i) => (",
      "              <tr key={i} className=\"border-t border-slate-100 hover:bg-slate-50\">",
      "                {columns.map((c) => (<td key={c.key} className={\"px-4 py-2 text-\" + ((c as any).align || \"left\") + \" text-slate-800\"}>{String((r as any)[c.key])}</td>))}",
      "              </tr>",
      "            ))}",
      "            {rows.length === 0 && (<tr><td colSpan={columns.length} className=\"px-4 py-6 text-center text-slate-500\">No results.</td></tr>)}",
      "          </tbody>",
      "        </table>",
      "      </div>",
      "      <footer className=\"p-3 text-xs text-slate-500 border-t border-slate-100\">Showing all records. Replace data with API call.</footer>",
      "      $0",
      "    </section>",
      "  );",
      "}"
