    "React Enterprise Component (sre)": {
      "prefix": "sre",
      "body": [
        "import React from 'react';",
        "",
        "interface ${1:ComponentName}Props {",
        "  className?: string;",
        "  children?: React.ReactNode;",
        "}",
        "",
        "export default function ${1:ComponentName}({",
        "  className = '',",
        "  children,",
        "}: ${1:ComponentName}Props) {",
        "  return (",
        "    <section className={`w-full rounded-2xl border bg-white p-6 shadow-sm ${className}`}>",
        "      <div className=\"mx-auto max-w-7xl\">",
        "        <h2 className=\"text-2xl font-semibold tracking-tight text-gray-900\">",
        "          ${2:Section Title}",
        "        </h2>",
        "",
        "        <p className=\"mt-2 text-sm leading-6 text-gray-600\">",
        "          ${3:Section description goes here.}",
        "        </p>",
        "",
        "        <div className=\"mt-6\">",
        "          {children || (",
        "            <div className=\"rounded-xl border border-dashed p-6 text-sm text-gray-500\">",
        "              ${0:Add your content here}",
        "            </div>",
        "          )}",
        "        </div>",
        "      </div>",
        "    </section>",
        "  );",
        "}"
      ],
      "description": "Create an enterprise-grade React TypeScript component with props, children, className, and Tailwind layout"
  },

