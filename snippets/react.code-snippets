  "Context Provider (srec)": {
    "prefix": "srec",
    "body": [
      "import React, { createContext, useContext, useState } from 'react';",
      "",
      "const ${1:Name}Context = createContext(null);",
      "export function ${1:Name}Provider({ children }) {",
      "  const [state, setState] = useState(null);",
      "  return <${1:Name}Context.Provider value={{ state, setState }}>{children}</${1:Name}Context.Provider>;",
      "}",
      "export const use${1:Name} = () => useContext(${1:Name}Context);"
    ],
    "description": "Context provider template"
  },

