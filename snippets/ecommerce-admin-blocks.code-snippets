  "Shelb E-com Account — AccountNotifications (seaccount09)": {
    "prefix": "seaccount09",
    "description": "Notification preferences (email / SMS / push toggles per category).",
    "body": [
      "import { useState } from \"react\";",
      "",
      "type Channel = \"email\" | \"sms\" | \"push\";",
      "const categories = [\"Orders\", \"Promotions\", \"Loyalty\", \"Security\"] as const;",
      "",
      "export default function seaccountAccountNotifications09() {",
      "  const [prefs, setPrefs] = useState<Record<string, Record<Channel, boolean>>>(() =>",
      "    Object.fromEntries(categories.map((c) => [c, { email: true, sms: false, push: c === \"Security\" }]))",
      "  );",
      "  function toggle(cat: string, ch: Channel) { setPrefs((p) => ({ ...p, [cat]: { ...p[cat], [ch]: !p[cat][ch] } })); }",
      "  return (",
      "    <table className=\"rounded-xl border border-gray-200 bg-white shadow-sm w-full text-sm\">",
      "      <thead className=\"bg-gray-50 text-xs uppercase text-gray-500\"><tr><th className=\"px-3 py-2 text-left\">Category</th><th>Email</th><th>SMS</th><th>Push</th></tr></thead>",
      "      <tbody>{categories.map((c) => (",
      "        <tr key={c} className=\"border-t border-gray-100\">",
      "          <td className=\"px-3 py-2 font-medium text-gray-900\">{c}</td>",
      "          {([\"email\",\"sms\",\"push\"] as Channel[]).map((ch) => (",
      "            <td key={ch} className=\"text-center\"><input type=\"checkbox\" checked={prefs[c][ch]} onChange={() => toggle(c, ch)} /></td>",
      "          ))}",
      "        </tr>",
      "      ))}</tbody>",
      "    </table>",
      "  );",
      "}",
      "$0"
    ]
  },
