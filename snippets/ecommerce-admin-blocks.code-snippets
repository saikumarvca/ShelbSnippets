  "Shelb E-com Account — AccountChangePassword (seaccount13)": {
    "prefix": "seaccount13",
    "description": "Standalone change-password form with confirmation field.",
    "body": [
      "import { useState, FormEvent } from \"react\";",
      "",
      "export default function seaccountAccountChangePassword13() {",
      "  const [current, setCurrent] = useState(\"\");",
      "  const [next, setNext] = useState(\"\");",
      "  const [confirm, setConfirm] = useState(\"\");",
      "  const [error, setError] = useState<string | null>(null);",
      "  async function save(e: FormEvent) {",
      "    e.preventDefault();",
      "    if (next !== confirm) { setError(\"Passwords do not match\"); return; }",
      "    setError(null);",
      "    await fetch(\"${1:/api/account/password}\", { method: \"PUT\", body: JSON.stringify({ current, next }) });",
      "  }",
      "  return (",
      "    <form onSubmit={save} className=\"rounded-xl border border-gray-200 bg-white p-4 shadow-sm max-w-md space-y-3\">",
      "      <h2 className=\"text-base font-semibold text-gray-900\">Change password</h2>",
      "      <input type=\"password\" value={current} onChange={(e) => setCurrent(e.target.value)} placeholder=\"Current\"     className=\"w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gray-900 focus:outline-none focus:ring-1 focus:ring-gray-900\" />",
      "      <input type=\"password\" value={next}    onChange={(e) => setNext(e.target.value)}    placeholder=\"New\"         className=\"w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gray-900 focus:outline-none focus:ring-1 focus:ring-gray-900\" />",
      "      <input type=\"password\" value={confirm} onChange={(e) => setConfirm(e.target.value)} placeholder=\"Confirm new\" className=\"w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gray-900 focus:outline-none focus:ring-1 focus:ring-gray-900\" />",
      "      {error && <p className=\"text-xs text-red-600\">{error}</p>}",
      "      <button type=\"submit\" className=\"inline-flex h-9 items-center rounded-md bg-gray-900 px-3 text-sm font-medium text-white hover:bg-black disabled:opacity-50\">Save</button>",
      "    </form>",
      "  );",
