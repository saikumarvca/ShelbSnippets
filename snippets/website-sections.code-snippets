      "}: Srecaro11Props) {",
      "",
      "  const Srecaro11Items = [",
      "    { id: \"1\", title: \"Slide 1\" }, { id: \"2\", title: \"Slide 2\" },",
      "    { id: \"3\", title: \"Slide 3\" }, { id: \"4\", title: \"Slide 4\" },",
      "    { id: \"5\", title: \"Slide 5\" }, { id: \"6\", title: \"Slide 6\" },",
      "  ];",
      "",
      "  const trackRef = useRef<HTMLUListElement>(null);",
      "  useEffect(() => {",
      "    const el = trackRef.current; if (!el) return;",
      "    const id = setInterval(() => {",
      "      const max = el.scrollWidth - el.clientWidth;",
      "      el.scrollLeft = el.scrollLeft >= max ? 0 : el.scrollLeft + 240;",
      "    }, 2500);",
      "    return () => clearInterval(id);",
      "  }, []);",
      "  return (",
      "    <section id={sectionId} className={\"bg-white text-gray-900 py-16 px-6 \" + className}>",
      "      <div className=\"mx-auto max-w-6xl\">",
