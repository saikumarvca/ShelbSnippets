      "  axios.create({ baseURL: process.env.${3:NEXT_PUBLIC_API_URL} }),",
      "  () => (typeof window !== 'undefined' ? localStorage.getItem('${4:auth_token}') : null)",
      ");",
      "$0"
    ]
