      "    const res = await fetch('${6:/api/auth/login}', {",
      "      method: 'POST',",
      "      headers: { 'Content-Type': 'application/json' },",
      "      body: JSON.stringify({ email, password })",
      "    });",
      "    if (!res.ok) throw new Error('${7:Login failed}');",
      "    const data = (await res.json()) as { token: string; user: ${2:AuthUser} };",
      "    setToken(data.token);",
      "    setUser(data.user);",
      "    window.localStorage.setItem('${5:auth_token}', data.token);",
      "  }, []);",
      "",
      "  const logout = useCallback(async () => {",
      "    setToken(null);",
      "    setUser(null);",
      "    window.localStorage.removeItem('${5:auth_token}');",
      "  }, []);",
      "",
      "  const value = useMemo(() => ({",
      "    user, token, isAuthenticated: !!token, login, logout",
      "  }), [user, token, login, logout]);",
      "",
      "  return <${1:AuthContext}.Provider value={value}>{children}</${1:AuthContext}.Provider>;",
      "}",
      "$0"
    ]
