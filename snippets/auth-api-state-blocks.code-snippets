      "  const [token, setToken] = useState<string | null>(null);",
      "",
      "  useEffect(() => {",
      "    if (typeof window === 'undefined') return;",
      "    const stored = window.localStorage.getItem('${5:auth_token}');",
      "    if (stored) setToken(stored);",
      "  }, []);",
