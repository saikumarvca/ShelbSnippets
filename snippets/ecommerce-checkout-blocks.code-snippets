  "Shelb E-com Cart — FullCart (secart04)": {
    "prefix": "secart04",
    "description": "Full cart page with items grid, vendor groups, coupon and totals card.",
    "body": [
      "import { useState } from \"react\";",
      "",
      "const sampleCart = [",
      "  { id: \"c_001\", productId: \"p_001\", title: \"Cotton Tee\",      qty: 2, price: 19.99, vendor: \"Atlas Apparel\" },",
      "  { id: \"c_002\", productId: \"p_002\", title: \"Denim Jacket\",    qty: 1, price: 79.99, vendor: \"Atlas Apparel\" },",
      "  { id: \"c_003\", productId: \"p_003\", title: \"Canvas Sneakers\", qty: 1, price: 49.99, vendor: \"Foot Co.\" },",
      "];",
      "",
      "export default function secartFullCart04() {",
      "  const [lines] = useState(sampleCart);",
      "  const [coupon, setCoupon] = useState(\"\");",
      "  const subtotal = lines.reduce((s, l) => s + l.qty * l.price, 0);",
      "  const shipping = lines.length ? 5 : 0;",
      "  const total = subtotal + shipping;",
      "  const byVendor = lines.reduce<Record<string, typeof lines>>((acc, l) => { (acc[l.vendor] = acc[l.vendor] || []).push(l); return acc; }, {});",
      "  return (",
      "    <main className=\"mx-auto grid max-w-5xl gap-4 p-6 md:grid-cols-3\">",
      "      <section className=\"space-y-4 md:col-span-2\">",
      "        {Object.entries(byVendor).map(([vendor, items]) => (",
      "          <div key={vendor} className=\"rounded-xl border border-gray-200 bg-white p-4 shadow-sm\">",
      "            <h3 className=\"text-sm font-semibold text-gray-900\">{vendor}</h3>",
      "            <ul className=\"mt-2 divide-y divide-gray-100\">",
      "              {items.map((l) => (",
      "                <li key={l.id} className=\"flex items-center justify-between py-2 text-sm\">",
      "                  <span>{l.title} × {l.qty}</span>",
      "                  <span>{\"$\" + (l.qty * l.price).toFixed(2)}</span>",
      "                </li>",
      "              ))}",
      "            </ul>",
      "          </div>",
      "        ))}",
      "      </section>",
      "      <aside className=\"rounded-xl border border-gray-200 bg-white p-4 shadow-sm h-fit space-y-2 text-sm\">",
      "        <p className=\"flex justify-between\"><span>Subtotal</span><span>{\"$\" + subtotal.toFixed(2)}</span></p>",
      "        <p className=\"flex justify-between text-gray-600\"><span>Shipping</span><span>{\"$\" + shipping.toFixed(2)}</span></p>",
      "        <p className=\"flex justify-between border-t border-gray-100 pt-2 font-semibold\"><span>Total</span><span>{\"$\" + total.toFixed(2)}</span></p>",
      "        <label className=\"block text-xs text-gray-500\">Coupon</label>",
      "        <input value={coupon} onChange={(e) => setCoupon(e.target.value)} className=\"w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gray-900 focus:outline-none focus:ring-1 focus:ring-gray-900\" placeholder=\"${1:SAVE10}\" />",
      "        <a href=\"${2:/checkout}\" className=\"inline-flex h-9 items-center rounded-md bg-gray-900 px-3 text-sm font-medium text-white hover:bg-black disabled:opacity-50 w-full justify-center\">Checkout</a>",
      "      </aside>",
      "    </main>",
      "  );",
      "}",
      "$0"
    ]
