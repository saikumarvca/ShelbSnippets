{
  "Shelb E-com Cart — BasicCart (secart01)": {
    "prefix": "secart01",
    "description": "Basic cart page with line items, totals, and empty state (React + TS + Tailwind).",
    "body": [
      "import { useState } from \"react\";",
      "",
      "const sampleCart = [",
      "  { id: \"c_001\", productId: \"p_001\", title: \"Cotton Tee\",      qty: 2, price: 19.99, vendor: \"Atlas Apparel\" },",
      "  { id: \"c_002\", productId: \"p_002\", title: \"Denim Jacket\",    qty: 1, price: 79.99, vendor: \"Atlas Apparel\" },",
      "  { id: \"c_003\", productId: \"p_003\", title: \"Canvas Sneakers\", qty: 1, price: 49.99, vendor: \"Foot Co.\" },",
      "];",
      "",
      "interface CartLine { id: string; productId: string; title: string; qty: number; price: number; vendor: string; }",
      "",
      "export default function secartBasicCart01() {",
      "  const [lines, setLines] = useState<CartLine[]>(sampleCart);",
      "  const [loading] = useState(false);",
      "  const subtotal = lines.reduce((s, l) => s + l.qty * l.price, 0);",
      "  const removeLine = (id: string) => setLines((ls) => ls.filter((l) => l.id !== id));",
      "  const updateQty = (id: string, qty: number) => setLines((ls) => ls.map((l) => (l.id === id ? { ...l, qty } : l)));",
      "",
      "  if (loading) return (",
      "    <div className=\"mx-auto max-w-3xl p-6\">",
      "      <div className=\"space-y-2\" aria-busy>",
      "        <div className=\"h-10 animate-pulse rounded-md bg-gray-100\" />",
      "        <div className=\"h-10 animate-pulse rounded-md bg-gray-100\" />",
      "        <div className=\"h-10 animate-pulse rounded-md bg-gray-100\" />",
      "      </div>",
      "    </div>",
      "  );",
      "  if (lines.length === 0) return (",
      "    <div className=\"mx-auto max-w-3xl p-6\">",
      "      <div className=\"flex flex-col items-center justify-center rounded-lg border border-dashed border-gray-300 bg-gray-50 px-4 py-8 text-center\">",
      "        <p className=\"text-sm text-gray-500\">Your cart is empty. Browse the catalog to add items.</p>",
      "      </div>",
      "    </div>",
      "  );",
      "",
      "  return (",
      "    <main className=\"mx-auto max-w-3xl space-y-4 p-6\">",
      "      <h1 className=\"text-2xl font-semibold text-gray-900\">${1:Your cart}</h1>",
      "      <ul className=\"rounded-xl border border-gray-200 bg-white shadow-sm divide-y divide-gray-100\">",
      "        {lines.map((l) => (",
      "          <li key={l.id} className=\"flex items-center gap-4 p-4\">",
      "            <div className=\"flex-1\">",
      "              <p className=\"text-sm font-medium text-gray-900\">{l.title}</p>",
      "              <p className=\"text-xs text-gray-500\">Sold by {l.vendor}</p>",
      "            </div>",
      "            <input type=\"number\" min={1} value={l.qty} onChange={(e) => updateQty(l.id, Number(e.target.value))} className=\"h-9 w-16 rounded-md border border-gray-300 px-2 text-sm\" />",
      "            <p className=\"w-20 text-right text-sm text-gray-900\">{\"$\" + (l.qty * l.price).toFixed(2)}</p>",
      "            <button type=\"button\" onClick={() => removeLine(l.id)} className=\"text-xs text-red-600 hover:underline\">Remove</button>",
      "          </li>",
      "        ))}",
      "      </ul>",
      "      <div className=\"rounded-xl border border-gray-200 bg-white p-4 shadow-sm flex items-center justify-between\">",
      "        <span className=\"text-sm text-gray-600\">Subtotal</span>",
      "        <span className=\"text-lg font-semibold text-gray-900\">{\"$\" + subtotal.toFixed(2)}</span>",
      "      </div>",
      "      <div className=\"flex justify-end gap-2\">",
      "        <a href=\"${2:/cart}\" className=\"inline-flex h-9 items-center rounded-md border border-gray-200 px-3 text-sm font-medium text-gray-700 hover:bg-gray-50\">Continue shopping</a>",
      "        <a href=\"${3:/checkout}\" className=\"inline-flex h-9 items-center rounded-md bg-gray-900 px-3 text-sm font-medium text-white hover:bg-black disabled:opacity-50\">Checkout</a>",
      "      </div>",
      "    </main>",
      "  );",
      "}",
      "$0"
    ]
  },
