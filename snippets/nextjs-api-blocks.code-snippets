  "Shelb Next Middleware — Comprehensive (snxmid20)": {
    "prefix": "snxmid20",
    "description": "Next.js comprehensive middleware combining auth, role, tenant, locale and security headers.",
    "body": [
      "import { NextResponse } from \"next/server\";",
      "import type { NextRequest } from \"next/server\";",
      "",
      "const LOCALES = [\"en\", \"fr\", \"hi\"] as const;",
      "",
      "function parseRole(token: string | undefined): string | null {",
      "  if (!token) return null;",
      "  try { return JSON.parse(atob(token.split(\".\")[1] ?? \"\")).role ?? null; } catch { return null; }",
      "}",
      "",
      "export function middleware(request: NextRequest) {",
      "  const { pathname } = request.nextUrl;",
      "  const token = request.cookies.get(\"${1:shelb_session}\")?.value;",
      "  const role = parseRole(token);",
      "  if (pathname.startsWith(\"/dashboard\") && !token) {",
      "    const url = request.nextUrl.clone(); url.pathname = \"${2:/login}\"; url.searchParams.set(\"next\", pathname);",
      "    return NextResponse.redirect(url);",
      "  }",
      "  if (pathname.startsWith(\"/admin\") && role !== \"${3:Admin}\") {",
      "    const url = request.nextUrl.clone(); url.pathname = \"${4:/forbidden}\"; return NextResponse.redirect(url);",
      "  }",
      "  const host = request.headers.get(\"host\") ?? \"\";",
      "  const tenant = host.split(\".\")[0];",
      "  const hasLocale = LOCALES.some((l) => pathname === \"/\" + l || pathname.startsWith(\"/\" + l + \"/\"));",
      "  if (!hasLocale && !pathname.startsWith(\"/api\")) {",
      "    const url = request.nextUrl.clone(); url.pathname = \"/${5:en}\" + pathname; return NextResponse.redirect(url);",
      "  }",
      "  const response = NextResponse.next();",
      "  if (tenant && ![\"www\", \"app\"].includes(tenant)) response.headers.set(\"x-tenant\", tenant);",
      "  response.headers.set(\"X-Frame-Options\", \"DENY\");",
      "  response.headers.set(\"X-Content-Type-Options\", \"nosniff\");",
      "  response.headers.set(\"Referrer-Policy\", \"strict-origin-when-cross-origin\");",
      "  return response;",
      "}",
      "",
      "export const config = { matcher: [\"/((?!_next|favicon.ico|api/health).*)\"] };$0"
    ]
  }
