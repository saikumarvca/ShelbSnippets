  "Shelb Next API — Auth Login (snxapi07)": {
    "prefix": "snxapi07",
    "description": "Next.js auth login route handler issuing an HttpOnly cookie.",
    "body": [
      "import { NextRequest, NextResponse } from \"next/server\";",
      "",
      "export async function POST(request: NextRequest) {",
      "  const { email, password } = await request.json();",
      "  if (!email || !password) return NextResponse.json({ error: \"Missing credentials\" }, { status: 400 });",
      "  const res = await fetch(\"${1:https://api.example.com/auth/login}\", { method: \"POST\", headers: { \"Content-Type\": \"application/json\" }, body: JSON.stringify({ email, password }) });",
      "  if (!res.ok) return NextResponse.json({ error: \"Invalid credentials\" }, { status: 401 });",
      "  const { token, user } = await res.json();",
      "  const response = NextResponse.json({ user });",
      "  response.cookies.set(\"${2:shelb_session}\", token, { httpOnly: true, secure: true, sameSite: \"lax\", path: \"/\", maxAge: 60 * 60 * 24 * 7 });",
      "  return response;",
      "}$0"
    ]
  },

