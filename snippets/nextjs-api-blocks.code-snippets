  "Shelb Next Middleware — Role (snxmid03)": {
    "prefix": "snxmid03",
    "description": "Next.js middleware checking a role claim in a session cookie payload.",
    "body": [
      "import { NextResponse } from \"next/server\";",
      "import type { NextRequest } from \"next/server\";",
      "",
      "function readRole(token: string | undefined): string | null {",
      "  if (!token) return null;",
      "  try { const payload = JSON.parse(atob(token.split(\".\")[1] ?? \"\")); return payload?.role ?? null; } catch { return null; }",
      "}",
      "",
      "export function middleware(request: NextRequest) {",
      "  const role = readRole(request.cookies.get(\"${1:shelb_session}\")?.value);",
      "  if (role !== \"${2:Admin}\") {",
      "    const url = request.nextUrl.clone(); url.pathname = \"${3:/forbidden}\"; return NextResponse.redirect(url);",
      "  }",
      "  return NextResponse.next();",
      "}",
      "",
      "export const config = { matcher: [\"${4:/admin/:path*}\"] };$0"
    ]
  },

