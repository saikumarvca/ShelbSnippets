  "Shelb Next Middleware — CSRF Token (snxmid17)": {
    "prefix": "snxmid17",
    "description": "Next.js middleware issuing a CSRF token cookie on safe methods.",
    "body": [
      "import { NextResponse } from \"next/server\";",
      "import type { NextRequest } from \"next/server\";",
      "",
      "export function middleware(request: NextRequest) {",
      "  const response = NextResponse.next();",
      "  if ([\"GET\", \"HEAD\", \"OPTIONS\"].includes(request.method)) {",
      "    if (!request.cookies.get(\"${1:csrf_token}\")) {",
      "      const token = crypto.randomUUID();",
      "      response.cookies.set(\"${1:csrf_token}\", token, { sameSite: \"lax\", secure: true, path: \"/\" });",
      "    }",
      "    return response;",
      "  }",
      "  const cookieToken = request.cookies.get(\"${1:csrf_token}\")?.value;",
      "  const headerToken = request.headers.get(\"${2:x-csrf-token}\");",
      "  if (!cookieToken || cookieToken !== headerToken) return NextResponse.json({ error: \"Invalid CSRF token\" }, { status: 403 });",
      "  return response;",
      "}",
      "",
      "export const config = { matcher: [\"/api/:path*\"] };$0"
    ]
  },

